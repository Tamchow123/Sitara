# Environment / secrets
.env
.env.local
.env.*.local

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
.ruff_cache/
apps/api/staticfiles/
# Local filesystem design-image storage (private; never committed)
apps/api/private-design-images/

# Node / Next.js
node_modules/
