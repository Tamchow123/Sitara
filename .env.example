# Sitara environment template — PLACEHOLDERS ONLY. Copy to .env and adjust.
# .env is gitignored; never commit real values. Docker Compose provides safe
# local-development defaults for everything, so a .env file is optional for
# local work.

# --- Core ------------------------------------------------------------------
# APP_ENV must be exactly one of: development | test | production.
# Anything else (e.g. "prod", "Production") refuses startup.
# Booleans are STRICT: 1/true/yes/on or 0/false/no/off (case-insensitive);
# any other value (e.g. "tru", "enable") refuses startup.
APP_ENV=development
DEBUG=true
# Production REJECTS placeholder sentinels (__REPLACE_ME__ / change-me) and
# the committed development values — replace before deploying.
DJANGO_SECRET_KEY=__REPLACE_ME__
# Production rejects development-only entries (localhost, 127.0.0.1, api…)
# per comma-separated entry; set ALLOW_INTERNAL_HOSTNAMES_IN_PRODUCTION=true
# ONLY for a documented internal reverse-proxy deployment.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
# ALLOW_INTERNAL_HOSTNAMES_IN_PRODUCTION=false

# --- Local development port binding ------------------------------------------
# Host-published dev ports bind to loopback only. Set 0.0.0.0 deliberately
# if you need LAN access to the dev stack.
BIND_HOST=127.0.0.1

# --- Data services ----------------------------------------------------------
DATABASE_URL=postgres://sitara:__REPLACE_ME__@localhost:5432/sitara
REDIS_URL=redis://localhost:6379/0
# Django cache (auth rate limiting) — separate logical DB from the broker.
# Docker uses redis://redis:6379/1. REQUIRED in production: startup fails on
# a missing/empty/placeholder value or on these committed development
# values, because auth rate limiting fails closed without the cache.
REDIS_CACHE_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Browser origins (explicit allowlists, never wildcards) ------------------
# Production requires these to be set explicitly; a deliberately same-origin
# deployment may instead set SAME_ORIGIN_DEPLOYMENT=true.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001
# SAME_ORIGIN_DEPLOYMENT=false

# --- Private S3-compatible object storage (MinIO locally) --------------------
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=__REPLACE_ME__
S3_SECRET_ACCESS_KEY=__REPLACE_ME__
S3_BUCKET_NAME=sitara-media
S3_REGION_NAME=us-east-1

# --- AI gates (fail-closed; Phase 2 decision defaults) -----------------------
DEFAULT_IMAGE_MODEL=black-forest-labs/flux-1.1-pro
FAST_IMAGE_MODEL=black-forest-labs/flux-1.1-pro
DEMO_MODE=true
ALLOW_PAID_AI_CALLS=false

# Deterministic zero-cost demo pipeline (Phase 15). Strictly bounded
# (non-negative integer, max 5000) — kept small enough to keep the genuine
# persisted progress states briefly visible for a demonstration; applies
# only to demo attempts, never to live generation. A reviewed demo asset
# pack must be installed via `manage.py install_demo_asset_pack` (or
# `--dev-synthetic` for local development only) before demo generation is
# available; an absent/incomplete/corrupt pack fails closed rather than
# falling back to a paid provider.
DEMO_STAGE_DELAY_MS=400

# Tokens: a present token NEVER enables provider calls on its own. Leave
# ANTHROPIC_API_KEY blank except for an explicitly authorised, budgeted live
# DesignSpec checkpoint (Phase 8) with DEMO_MODE=false and
# ALLOW_PAID_AI_CALLS=true; never commit a real key.
ANTHROPIC_API_KEY=
REPLICATE_API_TOKEN=

# Structured DesignSpec generation (Phase 8). ANTHROPIC_MODEL must be
# non-empty; the numeric values are strict positive integers. Never exposed
# via the public config endpoint.
ANTHROPIC_MODEL=claude-sonnet-4-6
DESIGN_SPEC_MAX_INPUT_CHARS=20000
DESIGN_SPEC_MAX_OUTPUT_TOKENS=4096
ANTHROPIC_TIMEOUT_SECONDS=60

# Gated Replicate image rendering (Phase 10). LIVE_GENERATION_ENABLED gates the
# public end-to-end generation API and defaults to false — leave it false
# except for an explicitly authorised, budgeted live checkpoint with
# DEMO_MODE=false, ALLOW_PAID_AI_CALLS=true and a real REPLICATE_API_TOKEN.
# A present token NEVER enables a call on its own. The numeric values are
# strict positive integers; the poll interval must be less than the poll
# timeout. The image model comes from DEFAULT_IMAGE_MODEL (above) and is never
# exposed via the public config endpoint.
LIVE_GENERATION_ENABLED=false
REPLICATE_TIMEOUT_SECONDS=30
REPLICATE_POLL_INTERVAL_SECONDS=2
REPLICATE_POLL_TIMEOUT_SECONDS=180
GENERATION_RAW_MAX_BYTES=20000000
GENERATION_RAW_MAX_PIXELS=40000000

# --- Live-generation cost accounting (Phase 16, Part A) -----------------------
# Integer micro-US-dollars (1 USD = 1_000_000 micro-USD). Everything fails
# closed. The daily budget defaults to 0, so live spend is impossible until an
# operator sets a positive ceiling AND a valid pricing profile — neither
# DEMO_MODE nor a present token nor LIVE_GENERATION_ENABLED can make demo mode
# spend money, and demo availability does not depend on any value here. NONE of
# these values is exposed through the public config endpoint. Prices are
# OPERATOR CONFIGURATION verified against official provider sources on a
# recorded date — never a hard-coded consequence of a model identifier; a model
# or price change MUST bump LIVE_GENERATION_PRICING_PROFILE so accounting can
# never continue under stale, unreviewed prices. Invalid or negative values
# refuse startup without echoing the supplied value.
LIVE_GENERATION_DAILY_BUDGET_MICRO_USD=0
LIVE_GENERATION_PRICING_PROFILE=
ANTHROPIC_INPUT_MICRO_USD_PER_MTOK=0
ANTHROPIC_OUTPUT_MICRO_USD_PER_MTOK=0
REPLICATE_MAX_IMAGE_MICRO_USD=0
# Conservative upper bound on the input-token count for one assembled Anthropic
# request; used with the input price to compute a never-under-reserving maximum.
ANTHROPIC_MAX_INPUT_TOKENS=8192
# Dedicated Redis logical database for the budget ledger — kept separate from
# Celery (DB 0) and the Django cache/throttles (DB 1) so budget keys have an
# exclusive namespace and are never evicted. Requires STANDALONE (non-cluster)
# Redis with persistence appropriate to the deployment and no arbitrary
# eviction of budget keys (see ADR 0017).
LIVE_GENERATION_BUDGET_REDIS_URL=redis://redis:6379/2
LIVE_GENERATION_BUDGET_REDIS_TIMEOUT_SECONDS=5

# --- Retention and stuck-job maintenance (Phase 16, Part C) ------------------
# Celery Beat runs two bounded, idempotent periodic tasks. Strict positive
# integers. The design purge (rows + permanent AND staging objects) is also the
# cleanup boundary for retained crash-recovery staging objects — a design's
# staging object lives at most DESIGN_RETENTION_DAYS.
DESIGN_RETENTION_DAYS=30
GENERATION_STUCK_AFTER_SECONDS=600
DESIGN_PURGE_BATCH_SIZE=50
GENERATION_STUCK_BATCH_SIZE=50
DESIGN_PURGE_INTERVAL_SECONDS=3600
GENERATION_STUCK_INTERVAL_SECONDS=120

# --- Security hardening and admin (Phase 16, Part D) -------------------------
# The Django admin is a staff-only operational surface. In production it is
# DISABLED by default (its route is not mounted at all); enable deliberately and
# only behind trusted access. Enabling it never bypasses staff/superuser checks.
DJANGO_ADMIN_ENABLED=true
# Production TLS/HSTS. SECURE_HSTS_SECONDS defaults to a full year in production;
# include-subdomains is on by default in production. HSTS PRELOAD is OFF by
# default and must never be enabled casually (it is effectively irreversible for
# the domain). Trusting X-Forwarded-Proto is opt-in only.
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=false
USE_X_FORWARDED_PROTO=false
# Bounded request body size / field count (defence in depth for the JSON API).
DATA_UPLOAD_MAX_MEMORY_SIZE=5242880
DATA_UPLOAD_MAX_NUMBER_FIELDS=1000

# --- Frontend Content-Security-Policy (Phase 16, Part D) ---------------------
# Space-separated allowlist of origins the browser may load signed <img> from
# (the S3/MinIO signing endpoint). NEVER a wildcard. Set server-side for the
# Next.js build; production must set this to the real signed-storage origin.
CSP_IMAGE_ORIGINS=http://localhost:9000 http://127.0.0.1:9000

# --- Authentication rate limits (Phase 3B) -----------------------------------
# Strict positive integers; invalid values refuse startup. Fixed windows on
# the Redis cache. Identifiers are HMAC-hashed before use in cache keys.
AUTH_LOGIN_IP_LIMIT=20
AUTH_LOGIN_IP_WINDOW_SECONDS=300
AUTH_LOGIN_EMAIL_LIMIT=5
AUTH_LOGIN_EMAIL_WINDOW_SECONDS=300
AUTH_REGISTER_IP_LIMIT=5
AUTH_REGISTER_IP_WINDOW_SECONDS=3600

# --- Design limits (Phase 4) --------------------------------------------------
# Versions allowed per design: the initial concept plus one refinement.
# Strict positive integer; invalid values refuse startup in EVERY
# environment, production included. Application-level rule (not a database
# constraint), deliberately absent from /api/v1/config/public —
# max_refinements already communicates the user-facing limit.
MAX_DESIGN_VERSIONS=2

# --- Inspiration catalogue (Phase 5B) -----------------------------------------
# Staff-only image-ingestion bounds. Strict positive integers; invalid
# values refuse startup in EVERY environment. Uploads above the byte limit
# are rejected before decoding; images above the pixel limit are rejected
# before full decode (decompression-bomb guard). Output WebP derivatives
# are capped at OUTPUT_MAX_EDGE / THUMBNAIL_EDGE pixels (never upscaled).
INSPIRATION_MAX_UPLOAD_BYTES=15000000
INSPIRATION_MAX_IMAGE_PIXELS=40000000
INSPIRATION_OUTPUT_MAX_EDGE=2048
INSPIRATION_THUMBNAIL_EDGE=512

# --- Permanent design-image storage and signed delivery (Phase 11) -----------
# Backend selection is STRICT and case-sensitive: exactly s3 or filesystem.
# s3 is the normal path (production and local MinIO); filesystem is for
# offline development/deterministic ingest testing ONLY (no public base URL,
# signed browser delivery deliberately unavailable, refused in production).
DESIGN_IMAGE_STORAGE_BACKEND=s3
# Private directory for the filesystem backend — outside static files and any
# publicly served media root. Only used (and required non-empty) when the
# filesystem backend is selected.
DESIGN_IMAGE_FILESYSTEM_ROOT=
# Canonical processing bounds. Strict positive integers; qualities must be
# 1-100; the thumbnail edge must not exceed the full-image max edge.
DESIGN_IMAGE_MAX_EDGE=2048
DESIGN_IMAGE_THUMBNAIL_EDGE=512
DESIGN_IMAGE_WEBP_QUALITY=90
DESIGN_IMAGE_THUMBNAIL_QUALITY=82
# Signed URL lifetime: 30-3600 seconds. Signed URLs are TEMPORARY BEARER
# URLs (anyone holding one may use it until expiry; logout does not revoke
# it) — keep this short and never log or store an issued URL.
DESIGN_IMAGE_SIGNED_URL_TTL_SECONDS=300
# BROWSER-reachable origin used ONLY to presign design-image GET URLs (the
# API talks to storage via S3_ENDPOINT_URL; a browser cannot resolve the
# internal Docker host). Blank = use the normal regional S3 endpoint.
# Production requires a clean HTTPS origin: no credentials, no query, no
# fragment, no path other than /.
S3_SIGNED_URL_ENDPOINT_URL=http://localhost:9000

# --- Frontend ----------------------------------------------------------------
# SERVER-ONLY: where the Next.js rewrite proxies /api/* requests. The browser
# always uses relative /api/ URLs against the web origin; no NEXT_PUBLIC_*
# backend URL exists any more (NEXT_PUBLIC_API_BASE_URL was removed in
# Phase 3B). Docker uses http://api:8000; native dev uses localhost:8000.
API_INTERNAL_BASE_URL=http://localhost:8000
