{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sitara.local/review/reviewer-report.schema.json",
  "title": "Council reviewer report",
  "description": "The exact structured object every council reviewer subagent returns. Written to .claude/review/reports/<slice>/<reviewer>.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["reviewer", "decision", "summary", "findings"],
  "properties": {
    "reviewer": {
      "type": "string",
      "enum": ["functionality", "clean-code", "architecture", "security", "testing", "reliability"]
    },
    "decision": {
      "type": "string",
      "enum": ["GOOD_TO_PROCEED", "PROCEED_WITH_MINOR_ISSUES", "CHANGES_REQUIRED", "BLOCKED_HIGH_PRIORITY"]
    },
    "summary": { "type": "string", "description": "One-paragraph verdict for this slice." },
    "reviewed_head": { "type": "string", "description": "HEAD SHA the reviewer saw." },
    "reviewed_diff_hash": { "type": "string", "description": "SHA-256 of the staged diff reviewed." },
    "findings": {
      "type": "array",
      "items": { "$ref": "reviewer-finding.schema.json" }
    }
  }
}
