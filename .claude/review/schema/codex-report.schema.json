{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sitara.local/review/codex-report.schema.json",
  "title": "Independent Codex review report",
  "description": "The strict JSON the read-only Codex reviewer must return for the complete phase diff.",
  "type": "object",
  "additionalProperties": false,
  "required": ["reviewer", "decision", "summary", "findings"],
  "properties": {
    "reviewer": { "type": "string", "const": "codex" },
    "decision": {
      "type": "string",
      "enum": ["GOOD_TO_PROCEED", "PROCEED_WITH_MINOR_ISSUES", "CHANGES_REQUIRED", "BLOCKED_HIGH_PRIORITY"]
    },
    "summary": { "type": "string" },
    "base_sha": { "type": "string" },
    "head_sha": { "type": "string" },
    "findings": {
      "type": "array",
      "items": { "$ref": "reviewer-finding.schema.json" }
    }
  }
}
