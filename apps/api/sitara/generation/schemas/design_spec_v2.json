  "additionalProperties": false,
  "description": "Version-2 DesignSpec: identical narrative structure to version 1 with a\ndedicated canonical neckline in ``source_selections``.\n\nOverriding ``schema_version`` and ``source_selections`` keeps their\noriginal field positions (Pydantic preserves the base declaration order for\noverridden fields), and the two inherited validators — the boolean\nschema-version guard and the semantic-invariant model validator — continue\nto apply.",
  "properties": {
    "colour_story": {
      "$ref": "#/$defs/ColourStory"
    },
    "concept_summary": {
      "maxLength": 700,
      "minLength": 80,
      "title": "Concept Summary",
      "type": "string"
    },
    "construction_caveats": {
      "items": {
        "maxLength": 400,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 6,
      "minItems": 1,
      "title": "Construction Caveats",
      "type": "array"
    },
    "coverage_and_drape": {
      "$ref": "#/$defs/CoverageAndDrape"
    },
    "cultural_context": {
      "$ref": "#/$defs/CulturalContext"
    },
    "embellishment_plan": {
      "$ref": "#/$defs/EmbellishmentPlan"
    },
    "fabrics_and_texture": {
      "items": {
        "$ref": "#/$defs/FabricEntry"
      },
      "maxItems": 8,
      "minItems": 1,
      "title": "Fabrics And Texture",
      "type": "array"
    },
    "garment_breakdown": {
      "$ref": "#/$defs/GarmentBreakdown"
    },
    "image_alt_text": {
      "maxLength": 300,
      "minLength": 40,
      "title": "Image Alt Text",
      "type": "string"
    },
    "schema_version": {
      "const": 2,
      "title": "Schema Version",
      "type": "integer"
    },
    "source_selections": {
      "$ref": "#/$defs/SourceSelectionsV2"
    },
    "styling_notes": {
      "items": {
        "maxLength": 400,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 8,
      "minItems": 1,
      "title": "Styling Notes",
      "type": "array"
    },
    "title": {
      "maxLength": 120,
      "minLength": 3,
      "title": "Title",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "source_selections",
    "title",
    "concept_summary",
    "garment_breakdown",
    "colour_story",
    "fabrics_and_texture",
    "embellishment_plan",
    "coverage_and_drape",
    "cultural_context",
    "styling_notes",
    "construction_caveats",
