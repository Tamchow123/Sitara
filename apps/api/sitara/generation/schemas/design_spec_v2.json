    "SourceSelectionsV2": {
      "additionalProperties": false,
      "description": "Version-2 source selections: adds the dedicated canonical neckline.\n\n``neckline_style`` is now the single authoritative neckline decision (the\nold ``high_neckline`` coverage value is retired from the questionnaire).\n``None`` means the user expressed no neckline preference. Every other field\nis inherited unchanged; ``extra=\"forbid\"`` still rejects any unknown key.",
      "properties": {
        "ceremony": {
          "pattern": "^[a-z][a-z0-9_]{1,63}$",
          "title": "Ceremony",
          "type": "string"
        },
        "colour_palette": {
          "items": {
            "pattern": "^[a-z][a-z0-9_]{1,63}$",
            "type": "string"
          },
          "maxItems": 8,
          "minItems": 1,
          "title": "Colour Palette",
          "type": "array"
        },
        "coverage_preferences": {
          "items": {
            "pattern": "^[a-z][a-z0-9_]{1,63}$",
            "type": "string"
          },
          "maxItems": 12,
          "title": "Coverage Preferences",
          "type": "array"
        },
        "dupatta_style": {
          "anyOf": [
            {
              "pattern": "^[a-z][a-z0-9_]{1,63}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Dupatta Style"
        },
        "embellishment_density": {
          "anyOf": [
            {
              "pattern": "^[a-z][a-z0-9_]{1,63}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Embellishment Density"
        },
        "embellishment_styles": {
          "items": {
            "pattern": "^[a-z][a-z0-9_]{1,63}$",
            "type": "string"
          },
          "maxItems": 8,
          "minItems": 1,
          "title": "Embellishment Styles",
          "type": "array"
        },
        "fabrics": {
          "items": {
            "pattern": "^[a-z][a-z0-9_]{1,63}$",
            "type": "string"
          },
          "maxItems": 8,
          "title": "Fabrics",
          "type": "array"
        },
        "garment_type": {
          "pattern": "^[a-z][a-z0-9_]{1,63}$",
          "title": "Garment Type",
          "type": "string"
        },
        "neckline_style": {
          "anyOf": [
            {
              "pattern": "^[a-z][a-z0-9_]{1,63}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Neckline Style"
        },
        "regional_style": {
          "anyOf": [
            {
              "pattern": "^[a-z][a-z0-9_]{1,63}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Regional Style"
        },
        "saree_drape": {
          "anyOf": [
            {
              "pattern": "^[a-z][a-z0-9_]{1,63}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Saree Drape"
        },
        "silhouette": {
          "pattern": "^[a-z][a-z0-9_]{1,63}$",
          "title": "Silhouette",
          "type": "string"
        }
      },
      "required": [
        "garment_type",
        "ceremony",
