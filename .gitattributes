# Generated OpenAPI contract files are byte-compared by the CI drift checks
# (backend schema + frontend types). Pin them to LF so generation on Linux
# CI and checkout on Windows/macOS never disagree over line endings.
apps/api/openapi/schema.json text eol=lf
apps/web/src/api/schema.d.ts text eol=lf

# The shared cross-language questionnaire validation contract is consumed by
# both the Django and the frontend test suites; pin it to LF so it reads
# identically on every platform.
contracts/questionnaire-validation-cases.json text eol=lf

