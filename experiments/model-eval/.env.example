# Copy to .env and fill in ONLY when you intend to run live generations.
# Automated tests and --dry-run never need any of these.

# Hard gate: live provider calls are refused unless this is exactly "true".
ALLOW_PROVIDER_CALLS=false

# Your Replicate API token. Never commit it; never paste it into logs or issues.
# REPLICATE_API_TOKEN=

# Note: a live run ALSO requires the CLI flags --budget-usd <amount> and
# --confirm-live. Setting the variables above is not sufficient on its own.
